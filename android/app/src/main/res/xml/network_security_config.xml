<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!--
      We’ll trust BOTH system and USER CAs so the emulator can trust
      Local’s self-signed root certificate after you install it on the emulator.
    -->
    <base-config>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Your local WP host over HTTPS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">houzilocal.local</domain>
    </domain-config>

    <!-- Allow cleartext traffic for local development server -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">172.16.100.201</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>

</network-security-config>
